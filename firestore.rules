rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to manage their own interview sessions
    match /interviews/{userId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow anyone to send contact messages (or restrict if needed)
    match /contacts/{contactId} {
      allow create: if true;
      allow read: if request.auth != null; // Only experts can read
    }
  }
}
